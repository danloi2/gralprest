#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/orcid@1.0.0/node_modules/orcid/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/orcid@1.0.0/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/orcid@1.0.0/node_modules/orcid/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/orcid@1.0.0/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../orcid@1.0.0/node_modules/orcid/dist/orcid.cjs" "$@"
else
  exec node  "$basedir/../../../../../orcid@1.0.0/node_modules/orcid/dist/orcid.cjs" "$@"
fi
