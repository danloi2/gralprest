#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/jupyter-book@2.1.2/node_modules/jupyter-book/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/jupyter-book@2.1.2/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/jupyter-book@2.1.2/node_modules/jupyter-book/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/jupyter-book@2.1.2/node_modules:/home/danloi/Documentos/projects/2026-gral/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../py/jupyter_book/dist/jupyter-book.cjs" "$@"
else
  exec node  "$basedir/../../py/jupyter_book/dist/jupyter-book.cjs" "$@"
fi
